{
    "compilerOptions": {
        "target": "ES2018",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": ["DOM", "ES2018"],
        "declaration": true,
        "outDir": "./dist",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}