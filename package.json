{
  "name": "@r146023/omniturbo",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "description": "A framework-agnostic governed path-state engine with schemas, datatypes, privacy, aliases, history, and subscriptions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "state",
    "store",
    "path",
    "schema",
    "validation",
    "typescript"
  ],
  "author": "Colemen Atwood",
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
